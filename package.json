{
  "name": "portwatch",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "dev:api": "wrangler pages dev --port 8786 --proxy 5174 --persist-to .wrangler/state",
    "build": "tsc -b && vp build",
    "lint": "eslint .",
    "preview": "vp preview",
    "prepare": "vp config",
    "test": "vp test",
    "cf:dev": "wrangler pages dev dist --port 8789",
    "cf:deploy": "wrangler pages deploy dist",
    "db:create": "wrangler d1 create portwatch-db",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply portwatch-db",
    "db:migrate:local": "wrangler d1 migrations apply portwatch-db --local",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:visual": "playwright test --config=playwright.visual.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hono/zod-validator": "^0.5.0",
    "@phosphor-icons/react": "^2.1.10",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0",
    "jose": "^5.10.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "recharts": "^3.8.0",
    "zod": "^3.25.55",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "wrangler": "^4.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
